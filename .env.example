# Copy this file to .env.local for development.
# Keep real values out of git.

NEXT_PUBLIC_APP_URL=http://localhost:3000

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

OPENAI_API_KEY=

# Generate with a long random string. Example:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SESSION_SECRET=

# Optional for Phase 1 local testing. Development defaults to demo users enabled.
# Set to false if you want to disable the built-in local demo accounts.
AUTH_ALLOW_DEV_DEMO_USERS=true
