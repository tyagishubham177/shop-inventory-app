# Copy this file to .env.local for development.
# Keep real values out of git.

NEXT_PUBLIC_APP_URL=http://localhost:3000

SUPABASE_URL=
SUPABASE_ANON_KEY=
# Required for server-side auth lookups against the app-managed users table.
SUPABASE_SERVICE_ROLE_KEY=

OPENAI_API_KEY=
# Optional. Defaults to gpt-4.1-mini if unset.
OPENAI_MODEL=gpt-4.1-mini

# Generate with a long random string. Example:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SESSION_SECRET=

# Optional in development.
# Demo users stay available as a fallback unless you set this to false.
# Set it to false after seeding the dev users table if you want to verify database-only auth.
AUTH_ALLOW_DEV_DEMO_USERS=true

